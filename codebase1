<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Golf Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<style>
  :root {
    --green: #1D9E75;
    --green-dark: #0F6E56;
    --green-light: #E1F5EE;
    --green-mid: #9FE1CB;
    --sand: #F7F4EE;
    --sand-dark: #EDE9DF;
    --ink: #1A1A18;
    --ink-mid: #4A4A45;
    --ink-light: #8A8A82;
    --white: #FFFFFF;
    --border: rgba(26,26,24,0.1);
    --border-mid: rgba(26,26,24,0.18);
    --red: #E24B4A;
    --amber: #BA7517;
    --amber-light: #FAEEDA;
    --blue-light: #E6F1FB;
    --blue-text: #042C53;
    --pink-light: #FBEAF0;
    --pink-text: #4B1528;
    --coral-light: #FAECE7;
    --coral-text: #4A1B0C;
    --purple-light: #EEEDFE;
    --purple-text: #26215C;
    --radius: 12px;
    --radius-sm: 8px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--sand);
    color: var(--ink);
    min-height: 100vh;
    font-size: 15px;
    line-height: 1.5;
  }

  /* ── SCREENS ── */
  .screen { display: none; min-height: 100vh; }
  .screen.active { display: block; }

  /* ── LOGIN ── */
  #login-screen {
    display: none;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 2rem;
    background: var(--sand);
  }
  #login-screen.active { display: flex; }

  .login-wrap { width: 100%; max-width: 380px; }

  .login-logo {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .login-logo-mark {
    width: 64px; height: 64px;
    background: var(--green);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1rem;
  }
  .login-logo-mark svg { width: 32px; height: 32px; }
  .login-logo h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 28px;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: -0.5px;
  }
  .login-logo p { font-size: 14px; color: var(--ink-light); margin-top: 4px; }

  .login-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
  }
  .login-card label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-light);
    margin-bottom: 6px;
  }
  .login-card select,
  .login-card input[type="password"] {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-sm);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    background: var(--white);
    color: var(--ink);
    margin-bottom: 1.25rem;
    outline: none;
    transition: border-color 0.15s;
    appearance: auto;
  }
  .login-card select:focus,
  .login-card input:focus { border-color: var(--green); }

  .btn-primary {
    width: 100%;
    background: var(--green);
    color: white;
    border: none;
    padding: 12px;
    border-radius: var(--radius-sm);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
  }
  .btn-primary:hover { background: var(--green-dark); }
  .btn-primary:active { transform: scale(0.99); }

  .login-hint {
    text-align: center;
    font-size: 12px;
    color: var(--ink-light);
    margin-top: 1rem;
  }
  .login-error {
    font-size: 13px;
    color: var(--red);
    margin-bottom: 1rem;
    display: none;
  }

  /* ── NAV ── */
  .nav {
    background: var(--white);
    border-bottom: 1px solid var(--border);
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 0;
    margin-right: auto;
    text-decoration: none;
  }
  .nav-brand-dot {
    width: 22px; height: 22px;
    background: var(--green);
    border-radius: 50%;
  }
  .nav-brand span {
    font-family: 'DM Serif Display', serif;
    font-size: 17px;
    color: var(--ink);
    letter-spacing: -0.3px;
  }
  .nav-tab {
    padding: 16px 13px;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-light);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .nav-tab:hover { color: var(--ink); }
  .nav-tab.active { color: var(--green); border-bottom-color: var(--green); }
  .nav-right { display: flex; align-items: center; gap: 8px; margin-left: 12px; }
  .nav-user { font-size: 13px; color: var(--ink-light); }
  .nav-logout {
    font-size: 12px;
    font-weight: 500;
    color: var(--green);
    cursor: pointer;
    padding: 6px 12px;
    border: 1px solid var(--green);
    border-radius: var(--radius-sm);
    transition: background 0.15s;
  }
  .nav-logout:hover { background: var(--green-light); }

  /* ── CONTENT ── */
  .content { padding: 2rem 1.5rem; max-width: 960px; margin: 0 auto; }

  .page { display: none; }
  .page.active { display: block; }

  .page-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .page-title {
    font-family: 'DM Serif Display', serif;
    font-size: 26px;
    font-weight: 400;
    letter-spacing: -0.5px;
    color: var(--ink);
  }

  /* ── CARDS ── */
  .card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .card-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ── STATS ── */
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 12px;
    margin-bottom: 1.5rem;
  }
  .stat {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
  }
  .stat-label { font-size: 12px; color: var(--ink-light); margin-bottom: 6px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; }
  .stat-val { font-family: 'DM Serif Display', serif; font-size: 28px; color: var(--ink); letter-spacing: -0.5px; }
  .stat-sub { font-size: 11px; color: var(--green); margin-top: 4px; font-weight: 500; }

  /* ── TABLE ── */
  .tbl-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th {
    text-align: left;
    padding: 8px 12px;
    font-size: 11px;
    font-weight: 600;
    color: var(--ink-light);
    border-bottom: 1px solid var(--border);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }
  td { padding: 11px 12px; border-bottom: 1px solid var(--border); color: var(--ink); vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--sand); }

  .badge {
    display: inline-block;
    padding: 3px 9px;
    border-radius: 99px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.03em;
  }
  .badge-green { background: var(--green-light); color: var(--green-dark); }
  .badge-gray { background: var(--sand-dark); color: var(--ink-mid); }

  /* ── AVATAR ── */
  .avatar {
    width: 28px; height: 28px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 600;
    flex-shrink: 0;
  }

  /* ── CHART ── */
  .chart-wrap { position: relative; height: 220px; }

  /* ── UPLOAD ── */
  .upload-zone {
    border: 2px dashed var(--border-mid);
    border-radius: var(--radius);
    padding: 2.5rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .upload-zone:hover { background: var(--sand); border-color: var(--green); }
  .upload-icon {
    width: 48px; height: 48px;
    background: var(--green-light);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1rem;
  }
  .upload-icon svg { width: 22px; height: 22px; stroke: var(--green); fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .upload-title { font-size: 15px; color: var(--ink-mid); }
  .upload-title span { color: var(--green); font-weight: 600; }
  .upload-sub { font-size: 12px; color: var(--ink-light); margin-top: 5px; }

  /* ── AI STATUS ── */
  .ai-status {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--ink-mid);
    padding: 0.875rem 1rem;
    background: var(--sand);
    border-radius: var(--radius-sm);
    margin-bottom: 1.25rem;
    border: 1px solid var(--border);
  }
  .ai-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); flex-shrink: 0; }
  .ai-dot.thinking { animation: blink 1s ease-in-out infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }

  /* ── FORM ── */
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-group label { font-size: 12px; font-weight: 600; color: var(--ink-light); text-transform: uppercase; letter-spacing: 0.05em; }
  .form-group input,
  .form-group select {
    padding: 9px 12px;
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-sm);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    background: var(--white);
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s;
    appearance: auto;
  }
  .form-group input:focus,
  .form-group select:focus { border-color: var(--green); }

  /* ── HOLE GRID ── */
  .hole-section-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink-light); margin: 1rem 0 0.5rem; }
  .hole-grid { display: grid; grid-template-columns: repeat(9, 1fr); gap: 4px; }
  .hole-cell { text-align: center; padding: 6px 3px; border-radius: 6px; }
  .hole-num { font-size: 9px; color: var(--ink-light); font-weight: 600; }
  .hole-par { font-size: 9px; color: var(--ink-light); }
  .hole-score { font-size: 14px; font-weight: 600; color: var(--ink); }
  .hole-diff { font-size: 9px; font-weight: 600; }
  .over { color: var(--red); }
  .under { color: var(--green); }
  .even { color: var(--ink-light); }
  .hole-cell.eagle { background: #E1F5EE; }
  .hole-cell.birdie { background: #9FE1CB; }
  .hole-cell.par { background: var(--sand); }
  .hole-cell.bogey { background: #FAEEDA; }
  .hole-cell.double { background: #FAC775; }
  .hole-cell.triple { background: #FAECE7; }

  /* ── SCORE SUMMARY ── */
  .score-summary { display: flex; gap: 10px; flex-wrap: wrap; margin: 1.25rem 0; }
  .score-pill {
    padding: 6px 14px;
    border-radius: 99px;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid var(--border);
    background: var(--white);
    color: var(--ink);
  }
  .score-pill.primary { background: var(--green); color: white; border-color: var(--green); }

  /* ── IMG PREVIEW ── */
  .img-preview { max-width: 100%; max-height: 200px; object-fit: contain; border-radius: var(--radius-sm); margin-bottom: 1.25rem; border: 1px solid var(--border); display: block; }

  /* ── ADMIN ── */
  .player-row { display: flex; align-items: center; gap: 14px; padding: 0.875rem 0; border-bottom: 1px solid var(--border); }
  .player-row:last-child { border-bottom: none; }
  .player-info { flex: 1; }
  .player-name { font-size: 14px; font-weight: 600; color: var(--ink); }
  .player-meta { font-size: 12px; color: var(--ink-light); margin-top: 2px; }

  /* ── TOAST ── */
  #toast {
    position: fixed;
    bottom: 1.5rem; right: 1.5rem;
    background: var(--ink);
    color: white;
    padding: 11px 18px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 500;
    z-index: 9999;
    display: none;
    animation: slideUp 0.2s ease;
    max-width: 320px;
  }
  #toast.success { background: var(--green); }
  #toast.error { background: var(--red); }
  @keyframes slideUp { from { transform: translateY(8px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

  /* ── EMPTY STATE ── */
  .empty { padding: 2rem; text-align: center; color: var(--ink-light); font-size: 14px; }

  .btn-danger {
    background: var(--red);
    color: white;
    border: none;
    padding: 9px 16px;
    border-radius: var(--radius-sm);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-danger:hover { opacity: 0.85; }

  .btn-save {
    background: var(--green);
    color: white;
    border: none;
    padding: 11px 24px;
    border-radius: var(--radius-sm);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
    margin-top: 0.5rem;
  }
  .btn-save:hover { background: var(--green-dark); }

  @media (max-width: 600px) {
    .form-row { grid-template-columns: 1fr; }
    .stat-grid { grid-template-columns: repeat(2, 1fr); }
    .nav-tab { padding: 14px 9px; font-size: 12px; }
    .content { padding: 1.25rem 1rem; }
  }
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen" class="screen active">
  <div class="login-wrap">
    <div class="login-logo">
      <div class="login-logo-mark">
        <svg viewBox="0 0 32 32" fill="none">
          <circle cx="16" cy="16" r="4" fill="white"/>
          <path d="M16 4 Q20 10 28 16 Q20 22 16 28 Q12 22 4 16 Q12 10 16 4Z" stroke="white" stroke-width="1.5" fill="none"/>
        </svg>
      </div>
      <h1>Golf Tracker</h1>
      <p>Bijhouden · Analyseren · Verbeteren</p>
    </div>
    <div class="login-card">
      <label>Speler</label>
      <select id="login-user">
        <option value="">— Kies je naam —</option>
        <option value="Jean">Jean (admin)</option>
        <option value="Gilles">Gilles</option>
        <option value="Aline">Aline</option>
        <option value="Julie">Julie</option>
        <option value="Bram">Bram</option>
      </select>
      <label>Wachtwoord</label>
      <input type="password" id="login-pw" placeholder="••••••" autocomplete="current-password">
      <div class="login-error" id="login-error"></div>
      <button class="btn-primary" onclick="doLogin()">Aanmelden</button>
      <p class="login-hint">Wachtwoord = naam in kleine letters</p>
    </div>
  </div>
</div>

<!-- MAIN APP -->
<div id="main-screen" class="screen">
  <nav class="nav">
    <div class="nav-brand">
      <div class="nav-brand-dot"></div>
      <span>Golf Tracker</span>
    </div>
    <div class="nav-tab active" onclick="showPage('dashboard')">Dashboard</div>
    <div class="nav-tab" onclick="showPage('upload')">Scorekaart</div>
    <div class="nav-tab" onclick="showPage('rondes')">Rondes</div>
    <div class="nav-tab" id="admin-tab" style="display:none" onclick="showPage('admin')">Admin</div>
    <div class="nav-right">
      <span class="nav-user" id="nav-username"></span>
      <span class="nav-logout" onclick="doLogout()">Afmelden</span>
    </div>
  </nav>

  <div class="content">

    <!-- DASHBOARD -->
    <div id="page-dashboard" class="page active">
      <div class="page-header">
        <h1 class="page-title" id="dashboard-title">Mijn overzicht</h1>
      </div>
      <div class="stat-grid" id="stat-grid">
        <div class="stat"><div class="stat-label">Laden</div><div class="stat-val">—</div></div>
      </div>
      <div class="card">
        <div class="card-title">Handicap evolutie</div>
        <div class="chart-wrap"><canvas id="hcp-chart"></canvas></div>
      </div>
      <div class="card">
        <div class="card-title">Recente rondes</div>
        <div class="tbl-wrap" id="recent-table"><div class="empty">Laden...</div></div>
      </div>
    </div>

    <!-- UPLOAD -->
    <div id="page-upload" class="page">
      <div class="page-header">
        <h1 class="page-title">Scorekaart uploaden</h1>
      </div>
      <div class="card">
        <div class="upload-zone" id="upload-zone" onclick="document.getElementById('file-input').click()">
          <div class="upload-icon">
            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
          </div>
          <p class="upload-title"><span>Kies een foto</span> of sleep hier naartoe</p>
          <p class="upload-sub">Foto van je scorekaart na de ronde</p>
        </div>
        <input type="file" id="file-input" accept="image/*" style="display:none" onchange="handleFile(event)">
      </div>

      <div class="card" id="result-panel" style="display:none">
        <div class="ai-status">
          <div class="ai-dot thinking" id="ai-dot"></div>
          <span id="ai-status-text">AI analyseert je scorekaart...</span>
        </div>
        <img id="img-preview" class="img-preview" style="display:none">
        <div id="scan-result" style="display:none">
          <div class="form-row">
            <div class="form-group"><label>Golfbaan</label><input type="text" id="res-baan"></div>
            <div class="form-group"><label>Datum</label><input type="date" id="res-datum"></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Par baan</label><input type="number" id="res-par" min="60" max="80" value="72"></div>
            <div class="form-group">
              <label>Type ronde</label>
              <select id="res-wedstrijd" onchange="toggleHcp()">
                <option value="nee">Oefenronde</option>
                <option value="ja">Wedstrijd</option>
              </select>
            </div>
          </div>
          <div id="wedstrijd-hcp" style="display:none;margin-bottom:14px;">
            <div class="form-group">
              <label>Nieuwe handicap-
